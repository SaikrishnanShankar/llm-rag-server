{
  "id": null,
  "uid": "rag-production-dashboard",
  "title": "Production LLM RAG Server",
  "tags": ["rag", "llm", "mlops"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rag_active_requests",
          "legendFormat": "Active",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "sum(rag_requests_total)",
          "legendFormat": "Total",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 3,
      "title": "Tokens / Second",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "rag_tokens_per_second",
          "legendFormat": "tok/s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 4,
      "title": "Request Latency p50 / p95 / p99 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(rag_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 5,
      "title": "Retrieval Latency p50 / p95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_retrieval_latency_seconds_bucket[5m])) by (le, chunk_strategy))",
          "legendFormat": "p50 {{chunk_strategy}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_retrieval_latency_seconds_bucket[5m])) by (le, chunk_strategy))",
          "legendFormat": "p95 {{chunk_strategy}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 6,
      "title": "RAGAS Faithfulness Score by Strategy",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rag_eval_faithfulness_score",
          "legendFormat": "{{chunk_strategy}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "RAGAS Context Relevance by Strategy",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 12 },
      "targets": [
        {
          "expr": "rag_eval_context_relevance_score",
          "legendFormat": "{{chunk_strategy}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "RAGAS Answer Relevance by Strategy",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 12 },
      "targets": [
        {
          "expr": "rag_eval_answer_relevance_score",
          "legendFormat": "{{chunk_strategy}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Request Rate by Strategy (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "sum(rate(rag_requests_total[1m])) by (chunk_strategy)",
          "legendFormat": "{{chunk_strategy}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 10,
      "title": "Error Rate by Strategy",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "targets": [
        {
          "expr": "sum(rate(rag_requests_total{status='error'}[5m])) by (chunk_strategy)",
          "legendFormat": "errors {{chunk_strategy}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 11,
      "title": "Chunks Ingested by Strategy",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rag_ingestion_chunks_total",
          "legendFormat": "{{chunk_strategy}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ]
}
