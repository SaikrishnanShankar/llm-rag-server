# ─── vLLM ────────────────────────────────────────────────────────────────────
# Local dev: leave as mock://local — the system uses mock_client.py
# PACE:      set to your vLLM server, e.g. http://pace-node-01:8000/v1
VLLM_BASE_URL=mock://local
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_TEMPERATURE=0.1
VLLM_MAX_TOKENS=1024

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
DATABASE_URL=postgresql://raguser:ragpassword@127.0.0.1:5433/ragdb

# ─── Embeddings ──────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ─── Retrieval ────────────────────────────────────────────────────────────────
DEFAULT_TOP_K=5
DEFAULT_CHUNK_STRATEGY=sentence   # fixed | sentence | semantic

# ─── MLflow ──────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=rag-chunking-comparison

# ─── Prometheus ──────────────────────────────────────────────────────────────
PROMETHEUS_PORT=8001

# ─── FastAPI ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
